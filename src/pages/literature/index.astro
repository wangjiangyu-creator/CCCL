---
import ResourceCard from "@components/ResourceCard.astro";
import ResourceFilter from "@components/ResourceFilter.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { byTopicOrder, contentSlug, resourcesByKind } from "@lib/collections";
import { getCollection } from "astro:content";

const allResources = await getCollection("resources");
const topics = (await getCollection("topics")).sort(byTopicOrder);
const resources = resourcesByKind(allResources, ["literature", "practice-note"]);
const kinds = [...new Set(resources.map((resource) => resource.data.kind))].sort();
const jurisdictions = [...new Set(resources.map((resource) => resource.data.jurisdiction))].sort();
const topicOptions = topics.map((topic) => ({ label: topic.data.title, value: contentSlug(topic) }));
const scholarshipCount = resources.filter((resource) => resource.data.kind === "literature").length;
const policyCount = resources.filter((resource) => resource.data.kind === "practice-note").length;
const chinaCount = resources.filter((resource) => resource.data.jurisdiction === "Mainland China").length;
---

<BaseLayout title="Literature" description="Scholarly and policy readings for LW6134.">
  <section class="hero">
    <div class="shell">
      <p class="eyebrow">Reading room</p>
      <h1 class="page-title">Literature</h1>
      <p class="lede">
        Policy materials, scholarly work, and official background notes that help
        students move from black-letter rules to institutional analysis.
      </p>
      <div class="stats-grid stats-grid--compact">
        <div class="stat">
          <strong>{scholarshipCount}</strong>
          <span>Scholarly readings</span>
        </div>
        <div class="stat">
          <strong>{policyCount}</strong>
          <span>Policy and practice notes</span>
        </div>
        <div class="stat">
          <strong>{chinaCount}</strong>
          <span>China-focused sources</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <ResourceFilter label="Filter literature" kinds={kinds} jurisdictions={jurisdictions} topicOptions={topicOptions} />
      <div class="record-grid">
        {resources.map((resource) => <ResourceCard resource={resource} />)}
      </div>
    </div>
  </section>
</BaseLayout>
