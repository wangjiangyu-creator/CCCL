---
import { navigation } from "@data/navigation";
import { withBase } from "@lib/paths";

const normalizePath = (path: string) => (path.endsWith("/") ? path : `${path}/`);
const currentPath = normalizePath(Astro.url.pathname);
---

<header class="site-header">
  <a class="skip-link" href="#main">Skip to content</a>
  <div class="shell site-header__inner">
    <a class="brand" href={withBase("/")}>
      <span>LW6134</span>
      <strong>Chinese and Comparative Company Law</strong>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      {
        navigation.map((item) => {
          const href = withBase(item.href);
          const active = currentPath.startsWith(normalizePath(href));
          return (
            <a
              href={href}
              class:list={{ "is-active": active }}
              aria-current={active ? "page" : undefined}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
